---
import type { WeekendEvent } from "../data/schema";

interface Props {
  event: WeekendEvent;
}

const { event } = Astro.props;
---

<article class="event-card">
  <div class="event-card__eyebrow">
    <span>{event.category}</span>
    <span>{event.area}</span>
  </div>
  <div class="event-card__header">
    <h3>{event.title}</h3>
    {event.editorialHighlight && <p class="event-card__badge">{event.editorialHighlight}</p>}
  </div>
  <p class="event-card__schedule">{event.schedule}</p>
  <p class="event-card__summary">{event.summary}</p>
  {event.tags && event.tags.length > 0 && (
    <ul class="event-card__tags" aria-label={`Tags for ${event.title}`}>
      {event.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
  <div class="event-card__footer">
    {event.price && <p class="event-card__price">{event.price}</p>}
    {event.url ? (
      <a href={event.url} target="_blank" rel="noreferrer">
        Check details
      </a>
    ) : (
      <p class="event-card__muted">No booking link needed for this pick.</p>
    )}
  </div>
</article>
